{
  "manifest_version": 3,
  "name": "Ronaldocu Böcek Filter",
  "version": "1.0.0",
  "description": "X/Twitter'da profil adında belirli bayrak emojileri bulunan ronaldocu böceklerin tweetlerini tarayıcıda gizler.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://mobile.x.com/*",
        "https://mobile.twitter.com/*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ronaldocu Böcek Filter"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
